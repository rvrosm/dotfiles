{
  ":": {
    "prefix": ":",
    "description": "name := value",
    "body": "$1 := $0"
  },
  "=": {
    "prefix": "=",
    "description": "name = value",
    "body": "$1 = $0"
  },
  "+=": {
    "prefix": "+=",
    "description": "name += value",
    "body": "$1 += $0"
  },
  "-=": {
    "prefix": "-=",
    "description": "name -= value",
    "body": "$1 -= $0"
  },
  "*=": {
    "prefix": "*=",
    "description": "name *= value",
    "body": "$1 -= $0"
  },
  "/=": {
    "prefix": "/=",
    "description": "name /= value",
    "body": "$1 /= $0"
  },
  "eq": {
    "prefix": "eq",
