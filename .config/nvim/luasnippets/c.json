    "body": "break "
  },
  "ca": {
    "prefix": "ca",
    "description": "case ...:",
    "body": [
      "case ${1:value}:",
      "\t${0:$TM_SELECTED_TEXT}"
    ]
  },
  "cr": {
    "prefix": "cr",
    "description": "char",
    "body": "char ${0:char}"
  },
  "cos": {
    "prefix": "cos",
    "description": "const ( ... )",
    "body": [
      "const (",
      "\t${1:NAME_type} = ${2:value}",
      "\t$0",
      ")"
    ]
  },
  "ci": {
    "prefix": "ci",
    "description": "const ( ... = iota )",
