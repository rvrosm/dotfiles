  "ra": {
    "prefix": "ra",
    "description": "range",
    "body": "range "
  },
  "rk": {
    "prefix": "rk",
    "description": "for v := range items { ... }",
    "body": [
      "for ${2:k} := range $1 {",
      "\t${0:$TM_SELECTED_TEXT}",
      "\\}"
    ]
  },
  "rv": {
    "prefix": "rv",
    "description": "for k, v := range items { ... }",
    "body": [
      "for _, ${2:v} := range $1 {",
      "\t${0:$TM_SELECTED_TEXT}",
      "\\}"
    ]
  },
  "sw": {
    "prefix": "sw",
    "description": "switch x { ... }",
    "body": [
      "switch ${1:var} {",
      "case ${2:value1}:",
      "    $3",
      "default:",
      "    $0",
      "\\}"
    ]
  },
  "ma": {
    "prefix": "ma",
    "description": "map[Type]Type",
    "body": "map[${1:string}]${0:string}"
  },
  "pa": {
    "prefix": "pa",
    "description": "package ...",
    "body": [
