  "ie": {
    "prefix": "ie",
    "description": "if ... else ...",
    "body": [
      "if ${1:condition} {",
      "\t${2:$TM_SELECTED_TEXT}",
      "\\} else {",
      "\t$0",
      "\\}"
    ]
  },
  "iei": {
    "prefix": "iei",
    "description": "if ... else if ...",
    "body": [
      "if ${1:condition} {",
      "\t${2:$TM_SELECTED_TEXT}",
      "\\} else if ${3:condition} {",
      "\t$0",
      "\\}"
