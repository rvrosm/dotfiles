    ]
  },
  "df": {
    "prefix": "df",
    "description": "defer someFunction()",
    "body": "defer ${1:func}"
  },
  "fs": {
    "prefix": "fs",
    "description": "for select",
    "body": [
      "for {",
      "    select {",
      "\tcase ${2:${1:result} := }<- ${3:channel}:",
      "\t    $0",
      "    \\}",
      "\\}"
    ]
  },
  "sl": {
    "prefix": "sl",
    "description": "select {case ...}",
    "body": [
      "select {",
      "    case ${2:${1:result} := }<- ${3:channel}:",
      "\t$0",
      "\\}"
    ]
  },
  "if": {
    "prefix": "if",
    "description": "if ... { ... }",
    "body": [
      "if ${1:condition} {",
      "\t${0:$TM_SELECTED_TEXT}",
      "\\}"
    ]
  },
  "i;": {
    "prefix": "i;",
    "description": "if; ... { ... }",
    "body": [
